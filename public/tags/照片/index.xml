      <description>&lt;p&gt;家人朋友想看的，主页微信联系我，告诉你密码。&lt;/p&gt;&#xA;&lt;h2 id=&#34;私密照片&#34;&gt;&#xD;&#xA;  私密照片&#xD;&#xA;  &lt;a class=&#34;heading-link&#34; href=&#34;#%e7%a7%81%e5%af%86%e7%85%a7%e7%89%87&#34;&gt;&#xD;&#xA;    &lt;i class=&#34;fa-solid fa-link&#34; aria-hidden=&#34;true&#34; title=&#34;Link to heading&#34;&gt;&lt;/i&gt;&#xD;&#xA;    &lt;span class=&#34;sr-only&#34;&gt;Link to heading&lt;/span&gt;&#xD;&#xA;  &lt;/a&gt;&#xD;&#xA;&lt;/h2&gt;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;secure-album-wrapper&#34; id=&#34;album-0&#34;&gt;&#xD;&#xA;  &#xD;&#xA;  &lt;div class=&#34;album-lock-screen&#34;&gt;&#xD;&#xA;    &lt;div class=&#34;lock-icon&#34;&gt;🔒&lt;/div&gt;&#xD;&#xA;    &lt;h3&gt;私密相册&lt;/h3&gt;&#xD;&#xA;    &lt;p&gt;请输入密码查看照片&lt;/p&gt;&#xD;&#xA;    &lt;input type=&#34;password&#34; id=&#34;pwd-0&#34; placeholder=&#34;输入密码&#34; autocomplete=&#34;off&#34; /&gt;&#xD;&#xA;    &lt;button onclick=&#34;unlockAlbum( 0 , &#39;7caf77d74ac7b78a06df13df6476ee433748baa1ab934a2daf8d37bed0e903a9&#39;)&#34;&gt;🔓 解锁查看&lt;/button&gt;&#xD;&#xA;    &lt;p id=&#34;error-0&#34; class=&#34;error-msg&#34; style=&#34;display:none;&#34;&gt;❌ 密码错误&lt;/p&gt;&#xD;&#xA;  &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;  &lt;div class=&#34;album-content&#34; style=&#34;display:none;&#34;&gt;&#xD;&#xA;    &lt;div class=&#34;masonry-album&#34;&gt;&#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%281%29.jpg&#34; alt=&#34;1 (1).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (1).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%2810%29.jpg&#34; alt=&#34;1 (10).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (10).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%282%29.jpg&#34; alt=&#34;1 (2).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (2).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%283%29.jpg&#34; alt=&#34;1 (3).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (3).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%284%29.jpg&#34; alt=&#34;1 (4).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (4).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%285%29.jpg&#34; alt=&#34;1 (5).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (5).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%286%29.jpg&#34; alt=&#34;1 (6).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (6).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%287%29.jpg&#34; alt=&#34;1 (7).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (7).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%288%29.jpg&#34; alt=&#34;1 (8).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (8).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;        &#xD;&#xA;          &#xD;&#xA;          &#xD;&#xA;          &lt;div class=&#34;masonry-item&#34;&gt;&#xD;&#xA;            &lt;img src=&#34;https://felixchang84.github.io/my-bolg/images/family/1%20%289%29.jpg&#34; alt=&#34;1 (9).jpg&#34; loading=&#34;lazy&#34; /&gt;&#xD;&#xA;            &lt;div class=&#34;photo-name&#34;&gt;1 (9).jpg&lt;/div&gt;&#xD;&#xA;          &lt;/div&gt;&#xD;&#xA;          &#xD;&#xA;        &#xD;&#xA;      &#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&lt;script src=&#34;https://cdn.jsdelivr.net/npm/crypto-js@4.1.1/crypto-js.min.js&#34;&gt;&lt;/script&gt;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;function unlockAlbum(id, correctHash) {&#xD;&#xA;  const pwd = document.getElementById(&#39;pwd-&#39; + id).value;&#xD;&#xA;  if (!pwd) {&#xD;&#xA;    alert(&#39;请输入密码&#39;);&#xD;&#xA;    return;&#xD;&#xA;  }&#xD;&#xA;  &#xD;&#xA;  const inputHash = CryptoJS.SHA256(pwd).toString();&#xD;&#xA;  &#xD;&#xA;  if (inputHash === correctHash) {&#xD;&#xA;    document.querySelector(&#39;#album-&#39; + id + &#39; .album-lock-screen&#39;).style.display = &#39;none&#39;;&#xD;&#xA;    document.querySelector(&#39;#album-&#39; + id + &#39; .album-content&#39;).style.display = &#39;block&#39;;&#xD;&#xA;    window.scrollTo({ top: document.querySelector(&#39;#album-&#39; + id + &#39; .album-content&#39;).offsetTop - 100, behavior: &#39;smooth&#39; });&#xD;&#xA;  } else {&#xD;&#xA;    document.getElementById(&#39;error-&#39; + id).style.display = &#39;block&#39;;&#xD;&#xA;    setTimeout(() =&gt; {&#xD;&#xA;      document.getElementById(&#39;error-&#39; + id).style.display = &#39;none&#39;;&#xD;&#xA;    }, 2000);&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;document.addEventListener(&#39;DOMContentLoaded&#39;, function() {&#xD;&#xA;  const inputs = document.querySelectorAll(&#39;.album-lock-screen input&#39;);&#xD;&#xA;  inputs.forEach(input =&gt; {&#xD;&#xA;    input.addEventListener(&#39;keypress&#39;, function(e) {&#xD;&#xA;      if (e.key === &#39;Enter&#39;) {&#xD;&#xA;        this.nextElementSibling.click();&#xD;&#xA;      }&#xD;&#xA;    });&#xD;&#xA;  });&#xD;&#xA;});&#xD;&#xA;&lt;/script&gt;&#xD;&#xA;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;.secure-album-wrapper {&#xD;&#xA;  margin: 30px 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.album-lock-screen {&#xD;&#xA;  text-align: center;&#xD;&#xA;  padding: 60px 30px;&#xD;&#xA;  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);&#xD;&#xA;  border-radius: 12px;&#xD;&#xA;  color: white;&#xD;&#xA;  box-shadow: 0 10px 30px rgba(0,0,0,0.2);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.lock-icon {&#xD;&#xA;  font-size: 48px;&#xD;&#xA;  margin-bottom: 15px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.album-lock-screen h3 {&#xD;&#xA;  margin: 10px 0;&#xD;&#xA;  font-size: 24px;&#xD;&#xA;  font-weight: 600;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.album-lock-screen p {&#xD;&#xA;  margin: 10px 0 20px;&#xD;&#xA;  opacity: 0.9;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.album-lock-screen input {&#xD;&#xA;  padding: 12px 16px;&#xD;&#xA;  font-size: 16px;&#xD;&#xA;  width: 280px;&#xD;&#xA;  max-width: 80%;&#xD;&#xA;  border: 2px solid rgba(255,255,255,0.3);&#xD;&#xA;  border-radius: 8px;&#xD;&#xA;  background: rgba(255,255,255,0.1);&#xD;&#xA;  color: white;&#xD;&#xA;  margin-bottom: 15px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.album-lock-screen input::placeholder {&#xD;&#xA;  color: rgba(255,255,255,0.6);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.album-lock-screen button {&#xD;&#xA;  padding: 12px 30px;&#xD;&#xA;  font-size: 16px;&#xD;&#xA;  background: white;&#xD;&#xA;  color: #667eea;&#xD;&#xA;  border: none;&#xD;&#xA;  border-radius: 8px;&#xD;&#xA;  cursor: pointer;&#xD;&#xA;  font-weight: 600;&#xD;&#xA;  transition: transform 0.2s;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.album-lock-screen button:hover {&#xD;&#xA;  transform: translateY(-2px);&#xD;&#xA;  box-shadow: 0 5px 15px rgba(0,0,0,0.2);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.error-msg {&#xD;&#xA;  margin-top: 15px;&#xD;&#xA;  color: #ffeb3b;&#xD;&#xA;  font-weight: 500;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA; &#xD;&#xA;.masonry-album {&#xD;&#xA;  column-count: 3;&#xD;&#xA;  column-gap: 15px;&#xD;&#xA;  padding: 20px 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.masonry-item {&#xD;&#xA;  break-inside: avoid;&#xD;&#xA;  margin-bottom: 15px;&#xD;&#xA;  position: relative;&#xD;&#xA;  border-radius: 10px;&#xD;&#xA;  overflow: hidden;&#xD;&#xA;  box-shadow: 0 4px 10px rgba(0,0,0,0.1);&#xD;&#xA;  background: #f8f9fa;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.masonry-item img {&#xD;&#xA;  width: 100%;&#xD;&#xA;  height: auto;&#xD;&#xA;  display: block;&#xD;&#xA;  transition: transform 0.4s ease;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.masonry-item:hover img {&#xD;&#xA;  transform: scale(1.05);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.photo-name {&#xD;&#xA;  position: absolute;&#xD;&#xA;  bottom: 0;&#xD;&#xA;  left: 0;&#xD;&#xA;  right: 0;&#xD;&#xA;  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);&#xD;&#xA;  color: white;&#xD;&#xA;  padding: 20px 10px 8px;&#xD;&#xA;  font-size: 12px;&#xD;&#xA;  opacity: 0;&#xD;&#xA;  transition: opacity 0.3s;&#xD;&#xA;  word-break: break-all;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.masonry-item:hover .photo-name {&#xD;&#xA;  opacity: 1;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA; &#xD;&#xA;@media (max-width: 1024px) {&#xD;&#xA;  .masonry-album {&#xD;&#xA;    column-count: 2;&#xD;&#xA;    column-gap: 12px;&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;@media (max-width: 768px) {&#xD;&#xA;  .masonry-album {&#xD;&#xA;    column-count: 2;&#xD;&#xA;    column-gap: 10px;&#xD;&#xA;  }&#xD;&#xA;  .masonry-item {&#xD;&#xA;    margin-bottom: 10px;&#xD;&#xA;  }&#xD;&#xA;  .album-lock-screen input {&#xD;&#xA;    width: 90%;&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;@media (max-width: 480px) {&#xD;&#xA;  .masonry-album {&#xD;&#xA;    column-count: 1;&#xD;&#xA;  }&#xD;&#xA;  .album-lock-screen {&#xD;&#xA;    padding: 40px 20px;&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&lt;/style&gt;&#xA;&lt;p&gt;这里又是公开区域。&lt;/p&gt;</description>
